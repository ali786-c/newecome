# Root .htaccess for cPanel Addon Domain
Options +FollowSymLinks
RewriteEngine On

# 0. Handle API storage assets directly (Bypass the real storage folder restriction)
RewriteRule ^api/storage/blog/(.*)$ api/storage/app/public/blog/$1 [L]

# 1. Forward API requests to the api folder (EXCEPT for storage assets)
RewriteCond %{REQUEST_URI} ^/api [NC]
RewriteCond %{REQUEST_URI} !^/api/storage [NC]
RewriteRule ^api/(.*)$ api/index.php [L]

# 2. Serve existing files/directories normally (for assets)
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# 3. All other requests go to index.html for React Router
RewriteRule ^ index.html [L]
